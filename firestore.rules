rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to validate submitted orders
    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'customer', 'outlet', 'status', 'total']) &&
             data.keys().size() <= 8 &&
             data.items is list && data.items.size() > 0 &&
             data.customer is map && data.customer.name is string && data.customer.phone is string &&
             data.outlet is string &&
             data.status is string && data.status in ['pending', 'preparing', 'out-for-delivery', 'delivered', 'cancelled'] &&
             data.total is number && data.total >= 0;
    }

    // Public catalog collections (Client reads and writes managed via Firestore)
    match /menuItems/{itemId} {
      allow read, write: if true;
    }

    match /promos/{promoId} {
      allow read, write: if true;
    }

    match /banners/{bannerId} {
      allow read, write: if true;
    }

    match /branches/{branchId} {
      allow read, write: if true;
    }

    // Orders collection (Client can create new orders with valid schema, and list/update status)
    match /orders/{orderId} {
      allow read: if true;
      allow create: if isValidOrder(request.resource.data);
      allow update: if true;
      allow delete: if false;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
